# Base URL of the FastAPI read API.
# Local dev:  http://localhost:8000
# Production: https://<api-host> — the DO API behind Caddy TLS (deploy/setup-proxy.sh),
#   e.g. https://203-0-113-7.sslip.io or https://api.yourdomain.com.
#   In production this is set in the Vercel project's Environment Variables
#   (it's read at build time, so set it before deploying).
NEXT_PUBLIC_API_BASE=http://localhost:8000
