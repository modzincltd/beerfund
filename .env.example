# Copy to .env for local dev, or use as the basis for the server's
# /etc/beerfund/beerfund.env (see deploy/DEPLOY.md). NEVER commit the real file.

# Free key from https://helius.dev
HELIUS_API_KEY=your-helius-key-here

# Space-separated Solana wallet addresses the paper daemon should follow.
# Used by the systemd service (deploy/beerfund-paper.service), not by the
# scripts directly when run by hand.
WALLETS=2QMCjkbBAkgvW9Az4ThWCUjB6L5oFfTgpbxeCrLi2xvQ

# Paper-trade tuning (optional; service defaults shown)
PAPER_SIZE=0.5          # simulated position size in SOL
PAPER_POLL=15           # seconds between polls
PAPER_MIN_SIGNAL=1.0    # ignore wallet buys smaller than this many SOL
PAPER_MAX_POSITIONS=8

# ---- Web/analysis layer (ingest, audit_runner, api) ----
# The trading workers ignore these; only the new layer reads them.

# Supabase Postgres. Use the "Direct connection" or "Session pooler" string
# from Supabase → Project Settings → Database (port 5432, NOT the 6543
# transaction pooler), and append ?sslmode=require.
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-REF.supabase.co:5432/postgres?sslmode=require

# Anthropic key for the AI analyst (/chat + /insights). Optional — the
# dashboard works without it.
ANTHROPIC_API_KEY=
BEERFUND_AI_MODEL=claude-sonnet-4-6

# Allowed browser origin(s) for the API. Your Vercel URL in prod; * for local.
CORS_ORIGINS=*
