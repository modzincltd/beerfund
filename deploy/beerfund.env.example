# Server environment for the paper daemon.
# Install to /etc/beerfund/beerfund.env (root:beerfund, chmod 640) — NOT in the repo.
#
#   sudo install -m 640 -o root -g beerfund deploy/beerfund.env.example \
#        /etc/beerfund/beerfund.env
#   sudo nano /etc/beerfund/beerfund.env        # fill in the real key
#   sudo systemctl restart beerfund-paper
#
# systemd reads this file (EnvironmentFile=) and injects every line as an env
# var. No quoting, no `export`, no inline comments on value lines.

# Free key from https://helius.dev  --  REQUIRED
HELIUS_API_KEY=your-helius-key-here

# Space-separated Solana wallet addresses to follow  --  REQUIRED
WALLETS=2QMCjkbBAkgvW9Az4ThWCUjB6L5oFfTgpbxeCrLi2xvQ

# Paper-trade tuning (optional; daemon defaults shown)
PAPER_SIZE=0.5
PAPER_POLL=15
PAPER_MIN_SIGNAL=1.0
PAPER_MAX_POSITIONS=8

# ---- Web/analysis layer (ingest, audit_runner, api) ------------------------
# Only the new services read these; the paper daemon ignores them.

# Supabase Postgres read model. "Direct connection" or "Session pooler" string
# from Supabase → Project Settings → Database (port 5432), with ?sslmode=require.
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-REF.supabase.co:5432/postgres?sslmode=require

# Anthropic key for the AI analyst (/chat and /insights). Optional — the REST
# dashboard works without it; only the AI features need it.
ANTHROPIC_API_KEY=
BEERFUND_AI_MODEL=claude-sonnet-4-6

# Allowed browser origin(s) for the API (your Vercel URL). Comma-separated.
# Use * only for local dev.
CORS_ORIGINS=https://your-app.vercel.app
